{
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "DIR": "coinstacks/bnbsmartchain/api",
      "PACKAGE": "@shapeshiftoss/bnbsmartchain-api"
    },
    "watchPatterns": [
      "node/coinstacks/bnbsmartchain/api/**",
      "node/coinstacks/common/**",
      "node/packages/**",
      "yarn.lock"
    ]
  },
  "deploy": {
    "startCommand": "node dist/bnbsmartchain/api/src/app.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    }
  }
}
