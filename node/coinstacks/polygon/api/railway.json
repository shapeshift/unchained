{
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "Dockerfile",
    "buildArgs": {
      "DIR": "coinstacks/polygon/api",
      "PACKAGE": "@shapeshiftoss/polygon-api"
    },
    "watchPatterns": ["node/coinstacks/polygon/api/**", "node/coinstacks/common/**", "node/packages/**", "yarn.lock"]
  },
  "deploy": {
    "startCommand": "node dist/polygon/api/src/app.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    }
  }
}
