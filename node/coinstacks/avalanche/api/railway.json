{
  "build": {
    "builder": "dockerfile",
    "dockerfilePath": "node/Dockerfile",
    "watchPatterns": [
      "node/coinstacks/avalanche/api/**",
      "node/coinstacks/common/api/**",
      "!node/coinstacks/common/api/src/utxo/**",
      "node/packages/**",
      "yarn.lock"
    ]
  },
  "deploy": {
    "startCommand": "node dist/avalanche/api/src/app.js",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    }
  }
}
